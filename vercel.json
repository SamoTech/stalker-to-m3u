{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/convert.py",   "use": "@vercel/python" },
    { "src": "api/test.py",      "use": "@vercel/python" },
    { "src": "api/validate.py",  "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/convert",  "dest": "/api/convert.py" },
    { "src": "/api/test",     "dest": "/api/test.py" },
    { "src": "/api/validate", "dest": "/api/validate.py" },
    { "src": "/",             "dest": "/public/index.html" }
  ]
}
