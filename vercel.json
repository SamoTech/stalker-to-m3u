{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/api/convert", "destination": "/api/convert.py" },
    { "source": "/api/test", "destination": "/api/test.py" }
  ],
  "functions": {
    "api/convert.py": { "maxDuration": 60, "memory": 512 },
    "api/test.py":    { "maxDuration": 15, "memory": 256 }
  }
}
